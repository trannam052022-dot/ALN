rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isFounder() {
      return request.auth != null &&
        request.auth.uid == 'h4kEguPEyMcwJwl89stc0Q6j2si2';
    }
    function signedIn() { return request.auth != null; }
    // isKts/isDesigner cấp quyền GHI lên stages của MỌI dự án (không member check) →
    // bắt buộc kèm status=='active': chỉ KTS/Designer đã được Founder DUYỆT mới có quyền.
    // KTS 'pending' (mới đăng ký) hoặc 'rejected' (bị từ chối) KHÔNG có quyền dù role=='kts'.
    // get() cùng path được rules cache trong 1 request → không tốn thêm lượt đọc.
    function isKts() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'kts' &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'active';
    }
    function isDesigner() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'designer' &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'active';
    }
    // Kế toán trưởng — chỉ đọc projects/designProjects (để đối chiếu khoản chi
    // KTS/Designer) + ghi RIÊNG field paymentChecks (đánh dấu "đã kiểm tra"
    // trước khi Founder tự tay chuyển tiền). Tuyệt đối không được đụng
    // payments/totalFee/escrow — quyền xác nhận đã chuyển vẫn chỉ Founder.
    function isKeToan() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ke_toan' &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'active';
    }
    function isMemberOfProject(pid) {
      let p = get(/databases/$(database)/documents/projects/$(pid)).data;
      return request.auth.uid in p.memberUids ||
        request.auth.uid == p.cn.uid ||
        request.auth.uid == p.kts.uid ||
        request.auth.uid == p.dn.uid;
    }
    function isMemberOfDesignProject(pid) {
      let p = get(/databases/$(database)/documents/designProjects/$(pid)).data;
      return request.auth.uid in p.memberUids ||
        request.auth.uid == p.designer.uid ||
        request.auth.uid == p.cn.uid ||
        (p.dn != null && request.auth.uid == p.dn.uid);
    }

    match /users/{uid} {
      allow read: if signedIn();
      // create: user tự tạo doc của mình KHÔNG được tự phong role đặc quyền. role phải
      // thuộc tập hợp lệ (chặn 'founder'); và status buộc 'pending' cho mọi role trừ 'cn'
      // (CN active ngay) → kẻ tự tạo role:'kts' vẫn kẹt 'pending', isKts() không cấp quyền
      // cho tới khi Founder duyệt. Founder (seed.html / admin) tạo tự do.
      allow create: if isFounder() || (
        signedIn() && request.auth.uid == uid &&
        request.resource.data.role in ['cn','kts','dn','designer','ks','ktv'] &&
        (request.resource.data.role == 'cn'
          ? request.resource.data.status == 'active'
          : request.resource.data.status == 'pending')
      );
      // update: user thường KHÔNG được tự sửa role LẪN status của chính mình (chặn leo
      // thang đặc quyền + tự kích active) — chỉ Founder đổi được. Bắt buộc vì rules diễn
      // đàn (PASS 2), isKts/isDesigner và Cloud Functions đều tin users/{uid}.role+status.
      allow update: if isFounder() || (
        request.auth.uid == uid &&
        request.resource.data.role == resource.data.role &&
        request.resource.data.status == resource.data.status
      );
      allow delete: if isFounder();
    }

    match /fcmTokens/{tokenId} {
      allow read:   if isFounder() || (signedIn() && resource.data.uid == request.auth.uid);
      allow create, update: if signedIn();
      allow delete: if isFounder() || (signedIn() && resource.data.uid == request.auth.uid);
    }

    match /settings/{docId} {
      allow read:  if signedIn();
      allow write: if isFounder();
    }

    match /messages/{docId} {
      allow read:   if signedIn();
      allow create: if signedIn();
      allow update, delete: if isFounder();
    }

    match /designerApplications/{uid} {
      allow read: if isFounder() || (signedIn() && request.auth.uid == uid);
      allow create: if signedIn() && request.auth.uid == uid;
      allow update: if isFounder() || (signedIn() && request.auth.uid == uid);
      allow delete: if isFounder();
    }

    match /designProjects/{pid} {
      allow read: if isFounder() || isKeToan() || (signedIn() && (
        request.auth.uid in resource.data.memberUids ||
        request.auth.uid == resource.data.designer.uid ||
        request.auth.uid == resource.data.cn.uid ||
        (resource.data.dn != null && request.auth.uid == resource.data.dn.uid)
      ));
      allow create: if isFounder();
      // Thành viên chỉ được sửa field thuộc luồng nghiệp vụ — CẤM sửa
      // totalFee/escrow/memberUids/designer/cn/dn (chống gian lận nội bộ).
      // Kế toán chỉ được ghi paymentChecks (đánh dấu đã đối chiếu).
      allow update: if isFounder() ||
        (signedIn() && request.auth.uid in resource.data.memberUids
          && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['stage', 'progress', 'updatedAt', 'payments'])) ||
        (isKeToan() && request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['paymentChecks', 'updatedAt']));
      allow delete: if isFounder();

      match /documents/{docId} {
        allow read:   if isFounder() || (signedIn() && isMemberOfDesignProject(pid));
        allow create: if isFounder() ||
          (signedIn() && request.resource.data.uploader.uid == request.auth.uid);
        allow update, delete: if isFounder() ||
          resource.data.uploader.uid == request.auth.uid;
      }

      match /stages/{sid} {
        allow read:  if signedIn();
        allow write: if isFounder() || isDesigner();

        match /proposals/{paId} {
          allow read:   if signedIn();
          allow create, update: if isFounder() || signedIn();
        }
      }
    }

    match /recruitPosts/{id} {
      allow read: if true;
      allow create, update, delete: if isFounder();
    }

    match /alnPosts/{id} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if isFounder() ||
        (signedIn() && request.auth.uid == resource.data.authorUid);
      allow delete: if isFounder() ||
        (signedIn() && request.auth.uid == resource.data.authorUid);
    }

    match /dnApplications/{uid} {
      allow read: if isFounder() || (signedIn() && request.auth.uid == uid);
      allow create: if signedIn() && request.auth.uid == uid;
      allow update: if isFounder() || (signedIn() && request.auth.uid == uid);
      allow delete: if isFounder();
    }

    match /ktsApplications/{uid} {
      allow read: if isFounder() || (signedIn() && request.auth.uid == uid);
      allow create: if signedIn() && request.auth.uid == uid;
      allow update: if isFounder() || (signedIn() && request.auth.uid == uid);
      allow delete: if isFounder();
    }

    match /ctvApplications/{uid} {
      allow read: if isFounder() || (signedIn() && request.auth.uid == uid);
      allow create: if signedIn() && request.auth.uid == uid;
      allow update: if isFounder() || (signedIn() && request.auth.uid == uid);
      allow delete: if isFounder();
    }

    // KS Vùng (ks-apply.html) — thiếu block này từ 28/06 khi đổi tên CTV→KS
    // (trang ghi ksApplications nhưng rules chỉ có ctvApplications cũ → form
    // hỏng âm thầm: tạo được tài khoản nhưng đơn bị deny, founder không thấy).
    match /ksApplications/{uid} {
      allow read: if isFounder() || (signedIn() && request.auth.uid == uid);
      allow create: if signedIn() && request.auth.uid == uid;
      allow update: if isFounder() || (signedIn() && request.auth.uid == uid);
      allow delete: if isFounder();
    }

    // KTV — Kỹ thuật viên triển khai hồ sơ (ktv-apply.html), cùng pattern.
    match /ktvApplications/{uid} {
      allow read: if isFounder() || (signedIn() && request.auth.uid == uid);
      allow create: if signedIn() && request.auth.uid == uid;
      allow update: if isFounder() || (signedIn() && request.auth.uid == uid);
      allow delete: if isFounder();
    }

    // Nhà cung cấp vật liệu (ncc-apply.html) — chỉ tham gia chuyên mục
    // "Vật liệu & Giá" trên Diễn đàn, cùng pattern các đơn đăng ký khác.
    // Gian hàng (Vietbuild ALN): doc ĐÃ DUYỆT đọc công khai — trang
    // ncc_profile.html + ncc-showcase.html (query where status=='approved').
    match /nccApplications/{uid} {
      allow read: if isFounder() || (signedIn() && request.auth.uid == uid)
                  || resource.data.status == 'approved';
      allow create: if signedIn() && request.auth.uid == uid;
      // Chính chủ tự cập nhật gian hàng (intro/gallery/catalog) nhưng KHÔNG
      // được tự đổi status — chặn tự duyệt để lên gian hàng công khai.
      allow update: if isFounder() ||
        (signedIn() && request.auth.uid == uid &&
         request.resource.data.status == resource.data.status);
      allow delete: if isFounder();
    }

    // Việc KTS giao KTV triển khai bản vẽ (kts_dashboard tab "Giao việc KTV" ↔ ktv_dashboard)
    match /ktvTasks/{tid} {
      function isKtv() {
        return request.auth != null &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ktv' &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'active';
      }
      // Đọc: Founder · KTS tạo việc · KTV được giao · KTV active thấy việc đang mở
      allow read: if isFounder()
        || (signedIn() && (resource.data.ktsUid == request.auth.uid || resource.data.ktvUid == request.auth.uid))
        || (resource.data.status == 'open' && isKtv());
      // Tạo: chỉ KTS active, và phải tự đứng tên ktsUid
      allow create: if isFounder() || (isKts() && request.resource.data.ktsUid == request.auth.uid);
      // Sửa: KTS chủ việc toàn quyền · KTV nhận việc mở (chỉ khi chưa ai nhận) ·
      //      KTV được giao cập nhật tiến độ/file (không đổi được ktsUid/ktvUid)
      allow update: if isFounder()
        || (signedIn() && resource.data.ktsUid == request.auth.uid)
        || (isKtv() && resource.data.status == 'open' && resource.data.ktvUid == null
            && request.resource.data.ktvUid == request.auth.uid)
        || (signedIn() && resource.data.ktvUid == request.auth.uid
            && request.resource.data.ktsUid == resource.data.ktsUid
            && request.resource.data.ktvUid == resource.data.ktvUid);
      // Xoá: Founder hoặc KTS chủ việc (nút Huỷ việc)
      allow delete: if isFounder() || (signedIn() && resource.data.ktsUid == request.auth.uid);
    }

    // Module Giữ chỗ — mỗi user chỉ đọc/ghi bản ghi của chính mình
    match /reservations/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      allow read, update: if isFounder();
    }

    match /newProjectRequests/{id} {
      allow create: if request.auth != null
        && request.resource.data.dnId == request.auth.uid;
      allow read: if request.auth != null
        && resource.data.dnId == request.auth.uid;
      allow update, delete: if false;
    }

    match /matchingRequests/{id} {
      allow read: if isFounder() || (signedIn() && resource.data.cnId == request.auth.uid);
      allow create: if signedIn();
      allow update: if isFounder() || (signedIn() && resource.data.cnId == request.auth.uid);
      allow delete: if false;
    }

    match /locationLogs/{id} {
      allow read: if isFounder();
      allow create: if signedIn();
    }

    match /projects/{pid} {
      // Chỉ THÀNH VIÊN của dự án (CN/KTS/DN) hoặc Founder mới đọc được.
      // Mỗi nhánh khớp với 1 kiểu query: cn.uid (CN), kts.uid (KTS),
      // dn.uid hoặc memberUids array-contains (DN). Người lạ bị chặn.
      allow read: if isFounder() || isKeToan() || (signedIn() && (
        request.auth.uid in resource.data.memberUids ||
        request.auth.uid == resource.data.cn.uid ||
        request.auth.uid == resource.data.kts.uid ||
        request.auth.uid == resource.data.dn.uid
      ));
      allow create: if isFounder();
      // Thành viên chỉ được sửa field thuộc luồng nghiệp vụ (CN/DN duyệt PA
      // → advance chặng + ghi payment record chờ Founder xác nhận). CẤM sửa
      // totalFee/escrow/memberUids/kts/cn/dn — chống thành viên gian lận
      // trạng thái, tự đổi số tiền hay thêm người vào dự án. Kế toán chỉ được
      // ghi paymentChecks (đánh dấu đã đối chiếu) — không đụng payments.
      allow update: if isFounder() ||
        (signedIn() && request.auth.uid in resource.data.memberUids
          && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['stage', 'progress', 'updatedAt', 'payments'])) ||
        (isKeToan() && request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['paymentChecks', 'updatedAt']));
      allow delete: if isFounder();

      match /documents/{docId} {
        allow read:   if isFounder() || (signedIn() && isMemberOfProject(pid));
        allow create: if isFounder() ||
          (signedIn() && request.resource.data.uploader.uid == request.auth.uid);
        allow update, delete: if isFounder() ||
          resource.data.uploader.uid == request.auth.uid;
      }

      match /stages/{sid} {
        allow read:  if signedIn();
        allow write: if isFounder() || isKts();

        match /proposals/{paId} {
          allow read:   if signedIn();
          allow create, update: if isFounder() || signedIn();

          match /pins/{pinId} {
            allow read:   if signedIn();
            allow create: if isFounder() ||
              (signedIn() && request.resource.data.author.uid == request.auth.uid);
            allow update, delete: if signedIn();
          }
        }

        match /comments/{cid} {
          allow read:   if signedIn();
          allow create: if isFounder() ||
            (signedIn() && request.resource.data.author.uid == request.auth.uid);
        }
      }
    }

    // Kho hồ sơ mẫu (gói kinh tế) — công khai đọc trên home.html, chỉ Founder ghi
    match /mauNha/{id} {
      allow read: if true;
      allow write: if isFounder();
    }

    // File gốc Kho hồ sơ mẫu — CHỈ Founder đọc/ghi, tách riêng khỏi mauNha để
    // link file gốc không bao giờ lộ ra qua document mà public đọc được.
    match /mauNhaGoc/{id} {
      allow read, write: if isFounder();
    }

    // Lead từ form khảo sát trang chủ — khách (kể cả ẩn danh) tạo được,
    // không đọc lại được (bảo mật), chỉ Founder xem/sửa/xoá.
    // Chống spam: bắt buộc có App Check token hợp lệ (chặn script/bot gọi
    // thẳng API ngoài trình duyệt thật) + kiểm tra dữ liệu hợp lệ cơ bản.
    match /landingLeads/{id} {
      allow create: if signedIn() && request.app != null
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0 && request.resource.data.name.size() < 100
        && request.resource.data.phone is string
        && request.resource.data.phone.size() >= 8 && request.resource.data.phone.size() < 20;
      allow read, update, delete: if isFounder();
    }

    // Nhật ký Phòng Hội Kiến — Cloud Function ghi (Admin SDK), client không
    // ghi/sửa/xoá được → nhật ký bất biến. Chỉ Founder đọc để giám sát.
    match /meetingLogs/{id} {
      allow read: if isFounder();
      allow write: if false;
    }

    // Bản nháp bài Marketing tự động (AI soạn hàng tuần) — chỉ Founder xem/sửa/xoá.
    // Ghi tạo mới chỉ qua Cloud Function (Admin SDK, bỏ qua rules) nên không cần allow create.
    match /marketingDrafts/{id} {
      allow read, update, delete: if isFounder();
    }

    // MyMy Agent Loop — DN chỉ đọc session của chính mình; ghi qua Cloud Function
    match /mymy_sessions/{dnId} {
      allow read: if signedIn() && request.auth.uid == dnId;
      allow write: if false;
      match /messages/{msgId} {
        allow read: if signedIn() && request.auth.uid == dnId;
        allow write: if false;
      }
    }

    /* ═══════════════════════════════════════════════════════════════
       DIỄN ĐÀN ALN (forum.html / kts_profile.html / founder_forum.html)
       Collection riêng (forumPosts...) — KHÔNG dùng chung với alnPosts
       của aln_community.html (Nhịp sống, tính năng khác).
       Mọi GHI đi qua Cloud Functions (functions/forum.js, Admin SDK,
       bỏ qua rules) → client chỉ ĐỌC; write: false toàn bộ.
       (notifBuffer/camNangForum/forumDigest/hoiKtsQueue không có block
       → mặc định deny, chỉ Cloud Function admin SDK đọc/ghi, đúng ý.)

       CHECKLIST_PHANQUYEN_DIENDAN_ALN.md PASS 2 — đọc CÔNG KHAI (kể cả
       chưa đăng nhập) cho bài/bình luận categoryVisibility=='public' và
       đang hiển thị. Nhánh public KHÔNG gọi get() nào (rẻ, || short-
       circuit) — get() chỉ chạy cho khu kts/dn như cũ.
    ═══════════════════════════════════════════════════════════════ */

    function fdProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function fdKtsActive() {
      return signedIn() && fdProfile().role == 'kts' &&
        fdProfile().get('status', 'active') == 'active';
    }
    function fdCnDnActive() {
      return signedIn() && fdProfile().role in ['cn', 'dn'] &&
        fdProfile().get('status', 'active') == 'active';
    }
    // Nhà cung cấp vật liệu (ncc-apply.html) — CHỈ chuyên mục "Vật liệu & Giá"
    function fdNccActive() {
      return signedIn() && fdProfile().role == 'ncc' &&
        fdProfile().get('status', 'active') == 'active';
    }
    function fdP2On() {
      return get(/databases/$(database)/documents/forumConfig/flags)
        .data.FORUM_P2_ENABLED == true;
    }
    // Chuyên mục CN/DN được đọc — hoi_dap/vat_lieu/nghe KTS-only VĨNH VIỄN
    function fdOpenCategory(cat) {
      return cat in ['tu_van_du_an', 'showcase', 'bang_tin'];
    }
    // Bài public đang hiển thị — đọc được kể cả không đăng nhập
    function fdPublicVisiblePost(d) {
      return d.categoryVisibility == 'public' && d.status == 'visible' && d.hidden == false;
    }

    match /forumPosts/{postId} {
      // CN/DN: chỉ đọc được doc thuộc chuyên mục mở VÀ khi cờ P2 bật —
      // query bắt buộc kèm where('category','in',[...]) mới qua được list.
      // NCC: chỉ đọc được đúng chuyên mục "vat_lieu".
      allow read: if fdPublicVisiblePost(resource.data) || isFounder() || fdKtsActive() ||
        (fdCnDnActive() && fdP2On() && fdOpenCategory(resource.data.category)) ||
        (fdNccActive() && resource.data.category == 'vat_lieu');
      allow write: if false;

      match /comments/{commentId} {
        allow read: if (resource.data.categoryVisibility == 'public' && resource.data.status == 'visible')
          || isFounder() || fdKtsActive() ||
          (fdCnDnActive() && fdP2On() && fdOpenCategory(
            get(/databases/$(database)/documents/forumPosts/$(postId)).data.category)) ||
          (fdNccActive() && get(/databases/$(database)/documents/forumPosts/$(postId)).data.category == 'vat_lieu');
        allow write: if false;
      }
    }

    match /forumConfig/{docId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /reports/{id} {
      allow read: if isFounder();
      allow write: if false;
    }

    match /modLogs/{id} {
      allow read: if isFounder();
      allow write: if false;
    }

    match /modQueue/{id} {
      allow read: if isFounder();
      allow write: if false;
    }

    match /invites/{id} {
      allow read: if isFounder() || (signedIn() && (
        resource.data.cnUid == request.auth.uid ||
        resource.data.ktsUid == request.auth.uid));
      allow write: if false;
    }

    match /leads/{id} {
      allow read: if isFounder();
      allow write: if false;
    }

    match /ktsReputation/{uid} {
      allow read: if signedIn();
      allow write: if false;
      match /events/{eventId} {
        allow read: if isFounder() || (signedIn() && request.auth.uid == uid);
        allow write: if false;
      }
    }

    match /forumUserState/{uid} {
      allow read: if isFounder() || (signedIn() && request.auth.uid == uid);
      allow write: if false;
    }
    /* ═══ HẾT BLOCK DIỄN ĐÀN ═══ */

    /* ═══════════════════════════════════════════════════════════════
       KTS CREATOR ALN — BẢN NHÁP (chưa nghiệm thu). Trang:
       kts_landing_draft.html / kts_creator_draft.html / founder_kts_creator_draft.html.
       Collection hậu tố _draft riêng, KHÔNG đụng alnPosts/forumPosts/leads/invites.
       Xem TONG_HOP_PHUONG_AN_KTS_CREATOR.md + BAN_GIAO_KTS_CREATOR.md.
       ═══════════════════════════════════════════════════════════════ */

    // Hồ sơ KTS Creator (mã KTS-XXXX, badge, tóm tắt portfolio) — đọc công khai cho
    // landing (KHÔNG bao giờ chứa SĐT/Zalo cá nhân). Chính chủ KTS active hoặc Founder ghi.
    match /kts_profiles_draft/{uid} {
      allow read: if true;
      allow create, update: if isFounder() || (signedIn() && request.auth.uid == uid && isKts());
      allow delete: if isFounder();
    }

    // Lead từ landing định danh KTS — khách (kể cả ẩn danh, qua signInAnonymously)
    // tạo được, không đọc lại (bảo mật) — giống hệt pattern landingLeads hiện có.
    match /leads_draft/{id} {
      allow create: if signedIn() && request.app != null
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0 && request.resource.data.name.size() < 100
        && request.resource.data.phone is string
        && request.resource.data.phone.size() >= 8 && request.resource.data.phone.size() < 20
        && request.resource.data.kts_ref is string;
      allow read, update, delete: if isFounder();
    }

    // Clip KTS Creator nộp duyệt — chính chủ tạo + xem của mình; chỉ Founder duyệt/sửa/xoá
    // (pilot founder duyệt tay — KHÔNG cơ chế tự động, đúng ĐIỀU KIỆN DỪNG CỨNG #3).
    match /clips_draft/{id} {
      allow read: if isFounder() || (signedIn() && resource.data.ktsUid == request.auth.uid);
      allow create: if (isFounder() || (signedIn() && isKts()))
        && request.resource.data.ktsUid == request.auth.uid
        && request.resource.data.status == 'cho_duyet';
      allow update, delete: if isFounder();
    }
  }
}
