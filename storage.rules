rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // KTS hồ sơ xin việc — chỉ owner upload, mọi user đã đăng nhập đọc được
    match /kts-profiles/{uid}/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // KTS bộ bản vẽ portfolio
    match /kts-portfolios/{uid}/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Board PA — mọi user đã đăng nhập (auth guard ở board-editor.html đã block)
    match /projects/{pid}/board-pa/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // Tài liệu dự án — thành viên dự án hoặc mọi user đã đăng nhập (upload tài liệu)
    match /projects/{pid}/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }

    // Ảnh cộng đồng (Nhịp sống ALN)
    match /community/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }

    // Ảnh hồ sơ Designer NT
    match /designer-profiles/{uid}/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Board PA — KTS/Designer/Founder upload được
    match /proposals/{pid}/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['kts', 'designer', 'founder'];
    }

    match /designProposals/{pid}/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['kts', 'designer', 'founder'];
    }

    // Settings công ty — chỉ founder
    match /settings/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == 'h4kEguPEyMcwJwl89stc0Q6j2si2';
    }

    // Kho hồ sơ mẫu (gói kinh tế) — ảnh công khai xem trên home.html, chỉ Founder upload/xoá
    match /mau/{allPaths=**} {
      allow read:  if true;
      allow write: if request.auth != null && request.auth.uid == 'h4kEguPEyMcwJwl89stc0Q6j2si2';
    }

    // File gốc Kho hồ sơ mẫu (đủ số liệu, độ phân giải cao) — CHỈ Founder đọc/ghi,
    // không public. Gửi riêng cho khách sau khi đặt mua thật, không đưa link này
    // vào bất kỳ document Firestore nào mà public đọc được (xem mauNhaGoc).
    match /mau-goc/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == 'h4kEguPEyMcwJwl89stc0Q6j2si2';
    }

    // Module Giữ chỗ — hồ sơ nộp (giấy phép, portfolio, ảnh công trình)
    match /reservations/{uid}/{file=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
